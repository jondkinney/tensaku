  <id>dev.tensaku.Tensaku</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MPL-2.0</project_license>
  <name>Tensaku</name>
  <summary>Modern Screenshot Annotation</summary>
  <icon type="stock">dev.tensaku.Tensaku</icon>
  <launchable type="desktop-id">dev.tensaku.Tensaku.desktop</launchable>
  <description>
    <p>
      Tensaku is a modern screenshot annotation tool for Linux, designed for wlroots-based compositors.
      It provides a simple, intuitive toolset for annotating screenshots with smooth hardware-accelerated rendering.
    </p>
    <p>
      Tensaku is a fork of Satty by Matthias Gabriel, used under the MPL-2.0 license.
    </p>
  </description>
  <screenshots>
    <screenshot type="default">
      <caption>The annotation canvas with the layer panel open — every mark stays selectable, draggable, and re-orderable</caption>
      <image>https://tensaku.dev/assets/screenshot-layer-panel.png</image>
    </screenshot>
  </screenshots>
  <categories>
    <category>Utility</category>
    <category>Graphics</category>
    <category>RasterGraphics</category>
  </categories>
